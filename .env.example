# .env.example — CORFO Analytics Platform
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas el archivo .env al repositorio.

# ── Autenticacion de usuarios ─────────────────────────────────────────────────

# Usuario administrador (acceso completo)
ADMIN_USERNAME=your_admin_username_here
ADMIN_PASSWORD=your_admin_password_here
ADMIN_ROLE=admin

# Usuario de solo lectura (opcional)
VIEWER_USERNAME=your_viewer_username_here
VIEWER_PASSWORD=your_viewer_password_here

# ── Seguridad de sesion Flask ─────────────────────────────────────────────────

# Clave secreta para firmar cookies de sesion.
# Genera una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# ── APIs externas ─────────────────────────────────────────────────────────────

# API key de Groq (backend LLM para generacion de SQL)
# Obtener en: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Token para la API de datainnovacion.cl (necesario para el sync mensual)
DATAINNOVACION_TOKEN=your_datainnovacion_token_here

# ── Base de datos ─────────────────────────────────────────────────────────────

# URL de PostgreSQL para produccion (opcional — si se omite, se usa SQLite local)
# Formato: postgresql://usuario:contrasena@host:5432/nombre_db
# DATABASE_URL=postgresql://user:password@localhost:5432/corfo_db

# Ruta al archivo SQLite (opcional — por defecto: corfo_alimentos.db en la raiz)
# DB_PATH=corfo_alimentos.db

# ── Configuracion del servidor ────────────────────────────────────────────────

# Puerto del servidor Flask (por defecto: 5000)
# PORT=5000

# Modo de Flask: "development" activa el modo debug
# FLASK_ENV=development
